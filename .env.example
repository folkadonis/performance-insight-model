# Copy to .env and fill in your values
# DO NOT commit .env to git

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-sonnet-4-6

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/campaign_intelligence
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/campaign_intelligence

# Redis
REDIS_URL=redis://localhost:6379/0
INSIGHT_CACHE_TTL=3600

# ML thresholds
ML_CONFIDENCE_THRESHOLD=0.60
INSIGHT_MIN_CONFIDENCE=55
MAX_INSIGHTS=12
MIN_INSIGHTS=8

# Resulticks MySQL (ProxySQL gateway — cross-schema: resulticksjobdb + resulticksmaster)
RESULTICKS_DB_HOST=10.200.2.195
RESULTICKS_DB_PORT=6033
RESULTICKS_DB_USER=res_pyuser
RESULTICKS_DB_PASSWORD=your_password_here
RESULTICKS_DB_NAME=resulticksjobdb

# Intent/Interest pipeline (shard DB + SDK API)
INTENT_DB_USER=res_apdev3138
INTENT_DB_PASSWORD=your_password_here
INTENT_API_T1=your_token_here
